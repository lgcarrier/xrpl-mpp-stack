# "single_token" or "redis_gateways"
GATEWAY_AUTH_MODE=single_token
XRPL_RPC_URL=https://s1.ripple.com:51234
MY_DESTINATION_ADDRESS=rYourXRPLReceivingAddressHere1234567890...
FACILITATOR_BEARER_TOKEN=replace-with-a-random-shared-secret
# use redis://redis:6379/0 in Docker Compose
REDIS_URL=redis://127.0.0.1:6379/0
# xrpl:0 = mainnet, xrpl:1 = testnet
NETWORK_ID=xrpl:0
# buyer-side network for examples; set to xrpl:1 for Testnet
XRPL_NETWORK=xrpl:0
# "validated" (recommended) or "optimistic"
SETTLEMENT_MODE=validated
VALIDATION_TIMEOUT=15
# 0.001 XRP minimum
MIN_XRP_DROPS=1000
# optional extra CODE:ISSUER pairs beyond built-in RLUSD/USDC
ALLOWED_ISSUED_ASSETS=
# set true only for local dev or trusted internal access
ENABLE_API_DOCS=false
# optional host port override for the facilitator Docker service
FACILITATOR_PORT=8000
# optional host port override for the merchant Docker service
MERCHANT_PORT=8010
# reject oversized payment requests before route handling
MAX_REQUEST_BODY_BYTES=32768
# 7 days of Redis replay markers
REPLAY_PROCESSED_TTL_SECONDS=604800
# public-mode freshness window in ledgers
MAX_PAYMENT_LEDGER_WINDOW=20
# buyer wallet seed for examples and Docker Compose demos
XRPL_WALLET_SEED=
# optional default spend cap for xrpl-mpp payer CLI/MCP budget checks
XRPL_MPP_MAX_SPEND=
# optional local receipt store override for xrpl-mpp payer
XRPL_MPP_RECEIPTS_PATH=
# shared HMAC secret for binding MPP challenges
MPP_CHALLENGE_SECRET=
# optional override for the middleware challenge realm
MPP_DEFAULT_REALM=
# middleware/facilitator challenge TTL in seconds
MPP_CHALLENGE_TTL_SECONDS=300
# idle timeout for XRPL MPP sessions
SESSION_IDLE_TIMEOUT_SECONDS=900
# Redis TTL for session state records
SESSION_STATE_TTL_SECONDS=604800
# XRP price for the merchant example
PRICE_DROPS=1000
# set to RLUSD or USDC for issued-asset demos
PRICE_ASSET_CODE=XRP
# issuer for issued-asset demos
PRICE_ASSET_ISSUER=
# issued-asset amount for merchant pricing
PRICE_ASSET_AMOUNT=
# buyer-side asset identifier, e.g. RLUSD:rIssuer
PAYMENT_ASSET=XRP:native
